---
const year = new Date().getFullYear();
import { Picture } from "astro:assets";
import { Building2, Mail, MapPin, Phone, Globe2 } from "lucide-react";
import Logo from "../../public/logo.webp";
---

<footer class="bg-moody-blue-950 text-gray-200">
  <div class="max-w-7xl px-4 md:px-8 mx-auto pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Columna 1: Identidad -->
      <div class="flex flex-col gap-4">
        <div class="flex gap-3 items-center">
          <Picture
            src={Logo}
            alt="Logo de Catalina"
            widths={[40, 80]}
            sizes="40px"
            width={40}
            height={30}
            loading="lazy"
            class="object-contain"
          />
          <h2 class="text-xl font-bold text-white">Catalina Herrera</h2>
        </div>
        <p class="text-sm leading-relaxed text-gray-300">
          Terapia Ocupacional dedicada al desarrollo integral de niños y
          adolescentes, en un ambiente acogedor y profesional.
        </p>
        <div class="flex flex-col gap-3 text-sm mt-2">
          <div class="flex gap-2 items-start text-white font-medium">
            <Building2 className="w-4 h-4 text-mint-400 mt-1 shrink-0" />
            <div class="flex flex-col">
              <span>Centro Inclusión SANA</span>
              <span class="text-xs text-gray-400 font-normal"
                >Convenio Vigente</span
              >
            </div>
          </div>
          <div class="flex gap-2 items-start text-white font-medium">
            <Globe2 className="w-4 h-4 text-mint-400 mt-1 shrink-0" />
            <div class="flex flex-col">
              <span>Atención Online (Todo Chile)</span>
              <span class="text-xs text-gray-400 font-normal"
                >Google Meet / Zoom / Teams</span
              >
            </div>
          </div>
          <div class="flex gap-2 items-start text-gray-300">
            <MapPin className="w-4 h-4 mt-1 shrink-0 text-mint-400" />
            <div class="flex flex-col">
              <span class="text-white font-medium">Atención a Domicilio</span>
              <span class="text-xs">Maipú, Cerrillos, Padre Hurtado</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Columna 2: Navegación -->
      <div class="flex flex-col gap-4">
        <h3 class="text-white font-bold text-lg">Navegación</h3>
        <ul class="flex flex-col gap-3 text-sm">
          <li>
            <a
              href="/"
              class="hover:text-white hover:translate-x-1 transition-all inline-block"
              >Inicio</a
            >
          </li>
          <li>
            <a
              href="/#sobre-mi"
              class="hover:text-white hover:translate-x-1 transition-all inline-block"
              >Sobre Mí</a
            >
          </li>
          <li>
            <a
              href="/#areas"
              class="hover:text-white hover:translate-x-1 transition-all inline-block"
              >Áreas de Intervención</a
            >
          </li>
          <li>
            <a
              href="/#donde"
              class="hover:text-white hover:translate-x-1 transition-all inline-block"
              >Ubicación</a
            >
          </li>
        </ul>
      </div>

      <!-- Columna 3: Pacientes -->
      <div class="flex flex-col gap-4">
        <h3 class="text-white font-bold text-lg">Pacientes</h3>
        <ul class="flex flex-col gap-3 text-sm">
          <li>
            <a
              href="/blog"
              class="hover:text-white hover:translate-x-1 transition-all inline-block"
              >Blog y Artículos</a
            >
          </li>
          <li>
            <a
              href="/normativas"
              class="hover:text-white hover:translate-x-1 transition-all inline-block"
              >Normativas de Atención</a
            >
          </li>
          <li>
            <a
              href="https://cal.com/catalina-herrera-ygpr9v"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white hover:translate-x-1 transition-all inline-block items-center gap-2"
            >
              Agendar Hora
              <span
                class="text-xs bg-mint-500/20 text-mint-300 px-2 py-0.5 rounded-full"
                >Online</span
              >
            </a>
          </li>
        </ul>
      </div>

      <!-- Columna 4: Contacto -->
      <div class="flex flex-col gap-4">
        <h3 class="text-white font-bold text-lg">Contacto</h3>
        <ul class="flex flex-col gap-3 text-sm">
          <li>
            <a
              href="mailto:catalina.herrera.to@gmail.com"
              class="hover:text-white transition-colors break-words flex items-center gap-2 group"
            >
              <Mail
                className="w-4 h-4 text-mint-400 group-hover:text-white transition-colors"
              />
              catalina.herrera.to@gmail.com
            </a>
          </li>
          <li>
            <a
              href="https://api.whatsapp.com/send?phone=56992194020"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition-colors flex items-center gap-2 group"
            >
              <Phone
                className="w-4 h-4 text-mint-400 group-hover:text-white transition-colors"
              />
              +56 9 9219 4020
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Barra inferior -->
    <div
      class="border-t border-moody-blue-800 pt-8 flex flex-col md:flex-row justify-center items-center gap-4 text-xs text-gray-300"
    >
      <span>
        © {year} Catalina Herrera. Todos los derechos reservados.
      </span>
    </div>
  </div>
</footer>
