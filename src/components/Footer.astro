---
const year = new Date().getFullYear()
import { Picture } from 'astro:assets'
import { Building2, Globe2, Mail, MapPin, Phone } from 'lucide-react'
import Logo from '../../public/logo.webp'
import { FOOTER_TEXTS } from '../data/footer.ts'
---

<footer class="bg-moody-blue-950 text-gray-200">
  <div class="max-w-7xl px-4 md:px-8 mx-auto pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Columna 1: Identidad -->
      <div class="flex flex-col gap-4">
        <div class="flex gap-3 items-center">
          <Picture
            src={Logo}
            alt={`${FOOTER_TEXTS.identity.logoAlt} ${FOOTER_TEXTS.identity.name}`}
            widths={[40, 80]}
            sizes="40px"
            width={40}
            height={30}
            loading="lazy"
            class="object-contain"
          />
          <h2 class="text-xl font-bold text-white">
            {FOOTER_TEXTS.identity.name}
          </h2>
        </div>
        <p class="text-sm leading-relaxed text-gray-300">
          {FOOTER_TEXTS.identity.description}
        </p>
        <div class="flex flex-col gap-3 text-sm mt-2">
          <div class="flex gap-2 items-start text-white font-medium">
            <Building2 className="w-4 h-4 text-mint-400 mt-1 shrink-0" />
            <div class="flex flex-col">
              <span>{FOOTER_TEXTS.identity.sana.name}</span>
              <span class="text-xs text-gray-400 font-normal">
                {FOOTER_TEXTS.identity.sana.agreement}
              </span>
            </div>
          </div>
          <div class="flex gap-2 items-start text-white font-medium">
            <Globe2 className="w-4 h-4 text-mint-400 mt-1 shrink-0" />
            <div class="flex flex-col">
              <span>{FOOTER_TEXTS.identity.online.text}</span>
              <span class="text-xs text-gray-400 font-normal">
                {FOOTER_TEXTS.identity.online.platforms}
              </span>
            </div>
          </div>
          <div class="flex gap-2 items-start text-gray-300">
            <MapPin className="w-4 h-4 mt-1 shrink-0 text-mint-400" />
            <div class="flex flex-col">
              <span class="text-white font-medium">
                {FOOTER_TEXTS.identity.home.text}
              </span>
              <span class="text-xs">{FOOTER_TEXTS.identity.home.communes}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Columna 2: Navegación -->
      <div class="flex flex-col gap-4">
        <h3 class="text-white font-bold text-lg">
          {FOOTER_TEXTS.navigation.title}
        </h3>
        <ul class="flex flex-col gap-3 text-sm">
          {
            FOOTER_TEXTS.navigation.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="hover:text-white hover:translate-x-1 transition-all inline-block"
                >
                  {link.text}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Columna 3: Pacientes -->
      <div class="flex flex-col gap-4">
        <h3 class="text-white font-bold text-lg">
          {FOOTER_TEXTS.patients.title}
        </h3>
        <ul class="flex flex-col gap-3 text-sm">
          <li>
            <a
              href={FOOTER_TEXTS.patients.regulations.href}
              class="hover:text-white hover:translate-x-1 transition-all inline-block"
            >
              {FOOTER_TEXTS.patients.regulations.text}
            </a>
          </li>
          <li>
            <a
              href={FOOTER_TEXTS.patients.schedule.href}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white hover:translate-x-1 transition-all inline-block items-center gap-2"
            >
              {FOOTER_TEXTS.patients.schedule.text}
              <span
                class="text-xs bg-mint-500/20 text-mint-300 px-2 py-0.5 rounded-full"
              >
                {FOOTER_TEXTS.patients.schedule.badge}
              </span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Columna 4: Contacto -->
      <div class="flex flex-col gap-4">
        <h3 class="text-white font-bold text-lg">
          {FOOTER_TEXTS.contact.title}
        </h3>
        <ul class="flex flex-col gap-3 text-sm">
          <li>
            <a
              href={`mailto:${FOOTER_TEXTS.contact.email}`}
              class="hover:text-white transition-colors break-words flex items-center gap-2 group"
            >
              <Mail
                className="w-4 h-4 text-mint-400 group-hover:text-white transition-colors"
              />
              {FOOTER_TEXTS.contact.email}
            </a>
          </li>
          <li>
            <a
              href={FOOTER_TEXTS.contact.whatsappLink}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition-colors flex items-center gap-2 group"
            >
              <Phone
                className="w-4 h-4 text-mint-400 group-hover:text-white transition-colors"
              />
              {FOOTER_TEXTS.contact.phone}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Barra inferior -->
    <div
      class="border-t border-moody-blue-800 pt-8 flex flex-col md:flex-row justify-center items-center gap-4 text-xs text-gray-300"
    >
      <span>
        © {year}
        {FOOTER_TEXTS.copyright}
      </span>
    </div>
  </div>
</footer>
