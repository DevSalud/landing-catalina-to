---
import { MapPin } from 'lucide-react'
import {
	ADDRESS_CITY,
	ADDRESS_REGION,
	ADDRESS_STREET,
	CENTER_NAME,
	MAPS_EMBED_QUERY,
} from '../../lib/constants'

const MAPS_API_KEY = import.meta.env.PUBLIC_MAPS_API_KEY
---

<section
  class="bg-moody-blue-950 flex flex-col justify-center h-full px-4 lg:px-0 text-white"
  id="donde"
>
  <div class="flex flex-col h-full mt-20 mx-auto mb-20 max-w-7xl px-4 md:px-8">
    <div class="text-center reveal">
      <span
        class="text-sm font-semibold text-moody-blue-300 uppercase tracking-wider"
        >Ubicación</span
      >
      <h2 class="text-3xl font-bold text-center mt-2">
        ¿Dónde puedes encontrarme?
      </h2>
      <p class="text-center text-gray-200">
        Consulta ubicada en un ambiente tranquilo y acogedor
      </p>
    </div>

    <div
      class="flex justify-center items-center md:w-[350px] md:h-[350px] w-full h-full mx-auto my-6 reveal"
      data-delay="1"
    >
      <iframe
        title="Google Maps"
        width="100%"
        height="100%"
        style="border:0"
        loading="lazy"
        allowfullscreen
        referrerpolicy="no-referrer-when-downgrade"
        src={`https://www.google.com/maps/embed/v1/place?key=${MAPS_API_KEY}&q=${MAPS_EMBED_QUERY}&zoom=15&maptype=roadmap`}
      ></iframe>
    </div>
    <div
      class="flex flex-col gap-2 items-center justify-center bg-moody-blue-900 px-10 py-5 rounded-xl lg:w-2xl mx-auto reveal"
      data-delay="2"
    >
      <div class="flex gap-2 items-center justify-center">
        <span class="text-moody-blue-400">
          <MapPin />
        </span>
        <h2 class="font-bold text-lg text-white">{CENTER_NAME}</h2>
      </div>
      <div class="flex flex-col items-center justify-center">
        <span class="text-gray-200">{ADDRESS_STREET}</span>
        <span class="text-gray-200">{ADDRESS_CITY}, {ADDRESS_REGION}</span>
      </div>
    </div>
  </div>
</section>
