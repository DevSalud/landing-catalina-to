---
import { Picture } from 'astro:assets'
import {
	Activity,
	ArrowRight,
	Calendar,
	CheckCircle2,
	GraduationCap,
	MapPin,
} from 'lucide-react'
import {
	ADDRESS_CITY,
	CALENDAR_URL,
	PROFESSIONAL_SINCE_YEAR,
	WHATSAPP_URL,
} from '../../lib/constants'
import ExternalButton from '../ui/ExternalButton.astro'
import WhatsappButton from '../ui/WhatsappButton.astro'

import CatalinaImage from '../../../public/images/Catalina.webp'
import '../../styles/components/hero.css'

const yearsOfExperience = new Date().getFullYear() - PROFESSIONAL_SINCE_YEAR
---

<section
  class="min-h-[calc(100vh-5rem)] w-full bg-white [background:radial-gradient(125%_125%_at_50%_10%,#fff_40%,#5434ce_100%)] pb-20 pt-8 flex justify-center items-center overflow-hidden"
>
  <div
    class="flex flex-col-reverse lg:flex-row justify-center h-full max-w-7xl px-4 md:px-8 items-center mx-auto gap-8 lg:gap-12"
  >
    <!-- Columna de texto -->
    <div class="flex-1 flex flex-col items-start lg:justify-center">
      <article class="flex flex-col items-start justify-center w-full gap-6">
        <!-- Badge Fonasa -->
        <div
          class="hero-item flex flex-col justify-center w-full lg:items-start items-center"
          style="--delay: 0ms"
        >
          <div
            class="inline-flex items-center gap-2 px-4 py-2 bg-green-50 border border-green-200 rounded-full text-green-700 font-medium text-sm md:text-base shadow-sm cursor-default"
          >
            <CheckCircle2 className="w-5 h-5 shrink-0" />
            <span>Atención con valores preferenciales Fonasa</span>
          </div>
        </div>

        <!-- H1 -->
        <div class="hero-item w-full" style="--delay: 100ms">
          <h1
            class="text-3xl md:text-4xl lg:text-5xl font-bold text-center lg:text-left text-moody-blue-700 leading-tight"
          >
            Terapia Ocupacional en {ADDRESS_CITY} para Niños y Adolescentes
          </h1>
        </div>

        <!-- Subtítulo -->
        <div class="hero-item w-full" style="--delay: 200ms">
          <h2
            class="text-xl md:text-2xl lg:text-3xl font-bold text-center lg:text-left text-gray-700"
          >
            Catalina Herrera, Terapeuta Ocupacional
          </h2>
        </div>

        <!-- Descripción -->
        <div class="hero-item w-full" style="--delay: 300ms">
          <p
            class="text-gray-600 md:text-lg lg:text-xl text-center lg:text-left leading-relaxed max-w-xl !m-0"
          >
            Ayudo a tu pequeño a desarrollar su máximo potencial a través del
            juego y actividades significativas
          </p>
        </div>

        <!-- CTAs -->
        <div
          class="hero-item flex gap-4 md:flex-row flex-col w-full md:w-auto mx-auto lg:mx-0"
          style="--delay: 400ms"
        >
          <ExternalButton
            href={CALENDAR_URL}
            text="Agenda tu primera sesión"
            icon={ArrowRight}
            data-tracker="hero-agendar"
          />
          <WhatsappButton
            href={WHATSAPP_URL}
            text="Escríbeme al WhatsApp"
            data-tracker="hero-whatsapp"
          />
        </div>

        <!-- Stats bar -->
        <div class="hero-item w-full" style="--delay: 500ms">
          <div
            class="flex flex-wrap justify-center lg:justify-start gap-x-6 gap-y-3 mt-2 pt-4 border-t border-moody-blue-100"
          >
            <div class="flex items-center gap-2 text-sm text-gray-600">
              <Calendar className="w-4 h-4 text-moody-blue-500 shrink-0" />
              <span>
                <strong class="text-gray-700 font-semibold"
                  >{yearsOfExperience}+ años</strong
                > de experiencia
              </span>
            </div>
            <div class="flex items-center gap-2 text-sm text-gray-600">
              <CheckCircle2 className="w-4 h-4 text-green-500 shrink-0" />
              <span
                ><strong class="text-gray-700 font-semibold">Fonasa</strong> aceptado</span
              >
            </div>
            <div class="flex items-center gap-2 text-sm text-gray-600">
              <Activity className="w-4 h-4 text-moody-blue-500 shrink-0" />
              <span
                ><strong class="text-gray-700 font-semibold">+100</strong> sesiones
                realizadas</span
              >
            </div>
            <div class="flex items-center gap-2 text-sm text-gray-600">
              <MapPin className="w-4 h-4 text-moody-blue-500 shrink-0" />
              <span
                >Atención en <strong class="text-gray-700 font-semibold"
                  >{ADDRESS_CITY}</strong
                ></span
              >
            </div>
            <div class="flex items-center gap-2 text-sm text-gray-600">
              <GraduationCap className="w-4 h-4 text-moody-blue-500 shrink-0" />
              <span
                ><strong class="text-gray-700 font-semibold"
                  >T.O. titulada</strong
                > U. Autónoma de Chile</span
              >
            </div>
          </div>
        </div>
      </article>
    </div>

    <!-- Columna de imagen -->
    <div class="flex-1 flex justify-center lg:justify-end hero-photo">
      <!-- Marco decorativo -->
      <div class="relative">
        <!-- Anillo exterior decorativo -->
        <div
          class="absolute inset-0 rounded-[50%] bg-gradient-to-br from-moody-blue-200 via-moody-blue-100 to-mint-200 scale-[1.08] opacity-60 blur-sm"
        >
        </div>
        <!-- Segundo aro con borde sólido -->
        <div
          class="absolute inset-0 rounded-[50%] border-4 border-moody-blue-200/50 scale-[1.04]"
        >
        </div>
        <!-- Dot decorativo superior derecho -->
        <div
          class="absolute -top-2 -right-2 w-8 h-8 rounded-full bg-mint-400 opacity-80 shadow-lg"
        >
        </div>
        <!-- Dot decorativo inferior izquierdo -->
        <div
          class="absolute -bottom-2 -left-2 w-5 h-5 rounded-full bg-moody-blue-400 opacity-70 shadow-md"
        >
        </div>

        <Picture
          src={CatalinaImage}
          alt="Foto de Catalina Herrera sonriendo"
          class="relative rounded-[50%] lg:w-80 lg:h-[26rem] w-44 h-56 object-cover object-[center_15%] shadow-2xl shadow-moody-blue-200"
          quality={80}
          loading={"eager"}
          fetchpriority={"high"}
          formats={["avif", "webp"]}
          widths={[200, 320, 480]}
          sizes="(max-width: 1024px) 200px, 320px"
          width={320}
          height={320}
        />
      </div>
    </div>
  </div>
</section>
