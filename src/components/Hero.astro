---
import { Picture } from 'astro:assets'
import { ArrowRight, CheckCircle2 } from 'lucide-react'
import ExternalButton from './common/ExternalButton.astro'
import WhatsappButton from './common/WhatsappButton.astro'

import CatalinaImage from '../../public/images/Catalina.webp'
---

<section
  class="min-h-[calc(100vh-5rem)] inset-0 -z-10 w-full bg-white [background:radial-gradient(125%_125%_at_50%_10%,#fff_40%,#5434ce_100%)] pb-20 flex justify-center items-center"
>
  <div
    class="flex flex-col-reverse lg:flex-row justify-center h-full max-w-7xl px-4 md:px-8 items-center mx-auto gap-5"
  >
    <div
      class="flex-1 flex flex-col gap-5 items-start lg:justify-center md:pt-10 pt-4"
    >
      <article class="flex flex-col items-start justify-center w-full">
        <div
          class="flex flex-col justify-center w-full lg:items-start items-center"
        >
          <div
            class="inline-flex items-center gap-2 px-4 py-2 bg-green-50 border border-green-200 rounded-full text-green-700 font-medium text-sm md:text-base shadow-sm hover:bg-green-100 transition-colors cursor-default mb-6"
          >
            <CheckCircle2 className="w-5 h-5" />
            <span>Atención con valores preferenciales Fonasa</span>
          </div>
        </div>
        <h1
          class="text-3xl md:text-4xl lg:text-5xl font-bold text-center lg:text-left mb-4 text-moody-blue-700 leading-tight"
        >
          Terapia Ocupacional en Maipú para Niños y Adolescentes
        </h1>
        <h2
          class="text-xl md:text-2xl lg:text-3xl font-bold text-center lg:text-left"
        >
          Catalina Herrera, Terapeuta Ocupacional
        </h2>

        <div class="flex flex-col gap-4 lg:items-start items-center">
          <p
            class="text-gray-700 md:text-lg lg:text-xl text-center lg:text-left leading-relaxed max-w-2xl"
          >
            Ayudo a tu pequeño a desarrollar su máximo potencial a través del
            juego y actividades significativas
          </p>
        </div>
        <div class="flex gap-5 md:flex-row flex-col mx-auto lg:mx-0 mt-5">
          <ExternalButton
            href="https://cal.com/catalina-herrera-ygpr9v"
            text="Agendar consulta"
            icon={ArrowRight}
          />
          <WhatsappButton
            href="https://api.whatsapp.com/send?phone=56992194020"
            text="WhatsApp"
            textClass="text-lg text-center"
          />
        </div>
      </article>
    </div>

    <div class="flex-1 flex justify-end fade-in">
      <Picture
        src={CatalinaImage}
        alt="Foto de Catalina Herrera sonriendo"
        class="rounded-full lg:w-96 object-cover w-48"
        quality={70}
        loading={"eager"}
        fetchpriority={"high"}
        widths={[320, 640, 960]}
        sizes="(max-width: 640px) 320px, (max-width: 1024px) 640px, 960px"
        width={960}
        height={960}
      />
    </div>
  </div>
</section>
