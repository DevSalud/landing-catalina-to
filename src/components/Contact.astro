---
import { CONTACT_TEXTS } from '@/data/contact'
import Button from './common/Button.astro'
import WhatsappButton from './common/WhatsappButton.astro'
---

<section
  class="w-full bg-white py-24 mx-auto relative overflow-hidden"
  id="contacto"
>
  <!-- Background Pattern -->
  <div class="absolute inset-0 pointer-events-none">
    <div
      class="absolute top-0 right-0 w-64 h-64 bg-moody-blue-50 rounded-bl-full opacity-50"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-48 h-48 bg-mint-50 rounded-tr-full opacity-50"
    >
    </div>
  </div>

  <div
    class="max-w-7xl px-4 md:px-8 mx-auto w-full flex flex-col gap-10 items-center justify-center relative z-10"
  >
    <div
      class="flex flex-col items-center justify-center text-center space-y-4 max-w-2xl"
    >
      <h2
        class="text-moody-blue-600 font-medium tracking-wide uppercase text-sm"
      >
        {CONTACT_TEXTS.subtitle}
      </h2>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900">
        {CONTACT_TEXTS.title}
      </h1>
      <p class="text-gray-600 text-lg leading-relaxed">
        {CONTACT_TEXTS.description}
      </p>
    </div>

    <div
      class="w-full max-w-xl p-8 md:p-10 rounded-3xl bg-white shadow-xl shadow-moody-blue-100 border border-moody-blue-50 flex flex-col gap-8 transform transition-all hover:shadow-2xl hover:shadow-moody-blue-200/50"
      data-contact-form
    >
      <WhatsappButton
        href={CONTACT_TEXTS.whatsapp.link}
        text={CONTACT_TEXTS.whatsapp.text}
        textClass="text-sm text-center"
      />

      <div class="flex relative justify-center">
        <div class="border-t border-gray-300 w-full"></div>
        <span
          class="text-gray-800 text-sm absolute -translate-y-1/2 bg-moody-blue-50 px-2"
        >
          {CONTACT_TEXTS.form.divider}
        </span>
      </div>
      <form class="flex flex-col gap-5" id="contacto-form">
        <div class="flex flex-col gap-2">
          <label for="nombre" class="text-gray-800">
            {CONTACT_TEXTS.form.fields.name.label}
          </label>
          <input
            type="text"
            id="nombre"
            class="w-full rounded-2xl py-2 px-3 text-gray-800 border border-moody-blue-200 focus:outline-none focus:border-moody-blue-500 focus:border-2"
            placeholder={CONTACT_TEXTS.form.fields.name.placeholder}
          />
          <span class="text-red-500 text-sm hidden" id="nombre-error">
            {CONTACT_TEXTS.form.fields.name.error}
          </span>
        </div>

        <div class="flex flex-col gap-2">
          <label for="email" class="text-gray-800">
            {CONTACT_TEXTS.form.fields.email.label}
          </label>
          <input
            type="email"
            id="email"
            class="w-full rounded-2xl py-2 px-3 text-gray-800 border border-moody-blue-200 focus:outline-none focus:border-moody-blue-500 focus:border-2"
            placeholder={CONTACT_TEXTS.form.fields.email.placeholder}
          />
          <span class="text-red-500 text-sm hidden" id="email-error">
            {CONTACT_TEXTS.form.fields.email.error}
          </span>
        </div>

        <div class="flex flex-col gap-2">
          <label for="mensaje" class="text-gray-800">
            {CONTACT_TEXTS.form.fields.message.label}
          </label>
          <textarea
            id="mensaje"
            class="w-full rounded-2xl py-2 px-3 text-gray-800 border border-moody-blue-200 focus:outline-none focus:border-moody-blue-500 focus:border-2 resize-none"
            rows="5"
            placeholder={CONTACT_TEXTS.form.fields.message.placeholder}
          ></textarea>
          <span class="text-red-500 text-sm hidden" id="mensaje-error">
            {CONTACT_TEXTS.form.fields.message.error}
          </span>
        </div>

        <Button text={CONTACT_TEXTS.form.button} type="submit" />
      </form>
    </div>
  </div>
</section>

<script>
  import { initContactForm } from '@/lib/contactForm'
  
  // Inicializar la lógica del formulario cuando el DOM esté listo
  initContactForm()
</script>