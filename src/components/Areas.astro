---
import { AREAS_TEXTS } from '@/data/areas'
import Baby from '/public/images/areas/baby.webp'
import Family from '/public/images/areas/family.webp'
import Inspiration from '/public/images/areas/inspiration.webp'
import Integration from '/public/images/areas/integracion.webp'
import Lifestyle from '/public/images/areas/lifestyle.webp'
import Psychomotricity from '/public/images/areas/psychomotricity.webp'
import ImageCard from './ui/ImageCard.astro'

const ICONS = [
	Integration,
	Inspiration,
	Lifestyle,
	Psychomotricity,
	Baby,
	Family,
]

const areas = AREAS_TEXTS.items.map((item, index) => ({
	...item,
	icon: ICONS[index],
}))
---

<section
  class="bg-white flex flex-col justify-center h-full py-24 relative overflow-hidden"
  id="areas"
>
  <!-- Decorative background elements -->
  <div
    class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none"
  >
    <div
      class="absolute top-0 right-0 w-1/3 h-1/3 bg-mint-50 rounded-bl-full opacity-50"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-1/4 h-1/4 bg-orchid-50 rounded-tr-full opacity-50"
    >
    </div>
  </div>

  <div
    class="max-w-7xl px-4 md:px-8 flex flex-col h-full gap-12 mx-auto relative z-10"
  >
    <div class="w-full text-center max-w-3xl mx-auto space-y-4">
      <h2
        class="text-moody-blue-600 font-medium tracking-wide uppercase text-sm"
      >
        {AREAS_TEXTS.subtitle}
      </h2>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900">
        {AREAS_TEXTS.title}
      </h1>
      <p class="text-gray-600 text-lg leading-relaxed">
        {AREAS_TEXTS.description}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        areas.map((area) => (
          <ImageCard
            title={area.title}
            description={area.description}
            image={area.icon}
            alt={area.alt}
            variant="mint"
            expandableDescription={true}
          />
        ))
      }
    </div>
  </div>
</section>
