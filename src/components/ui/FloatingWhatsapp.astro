---
import { WHATSAPP_URL } from '../../lib/constants'
import Whatsapp from '../icons/Whatsapp.astro'
---

<div
  class="fixed bottom-6 right-6 z-[90] flex items-center justify-center group"
  role="complementary"
  aria-label="Acceso rápido a WhatsApp"
>
  <!-- Círculo de pulso animado de fondo -->
  <span
    class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-500 opacity-40 group-hover:opacity-60 transition-opacity duration-300"
    aria-hidden="true"></span>

  <!-- Botón principal -->
  <a
    href={WHATSAPP_URL}
    target="_blank"
    data-umami-event="floating-whatsapp"
    rel="noopener noreferrer"
    class="relative flex items-center justify-center w-14 h-14 bg-[#25D366] text-white rounded-full shadow-lg shadow-green-900/20 hover:bg-[#1ebe57] transition-all duration-300 hover:-translate-y-1 hover:scale-105"
    aria-label="Contactar por WhatsApp"
    title="Chatea conmigo en WhatsApp"
  >
    <!-- Contenedor del ícono para ajustar tamaño -->
    <div class="w-8 h-8 flex items-center justify-center" aria-hidden="true">
      <Whatsapp />
    </div>
  </a>
</div>
