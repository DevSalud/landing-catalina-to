---
import { ArrowRight, Check } from 'lucide-react'
import ExternalButton from './ExternalButton.astro'

interface Props extends astroHTML.JSX.HTMLAttributes {
	title: string
	price: string
	description: string
	features: string[]
	isHighlighted?: boolean
	highlightText?: string
	buttonVariant?: 'primary' | 'secondary' | 'whatsapp'
	href?: string
}

const {
	title,
	price,
	description,
	features,
	isHighlighted = false,
	highlightText = 'Más Elegido',
	href,
	...rest
} = Astro.props

// Formateamos el precio para asegurarnos que tenga el separador de miles
const formattedPrice = new Intl.NumberFormat('es-CL', {
	style: 'decimal',
	minimumFractionDigits: 0,
}).format(Number(price))
---

<article
  class={`relative flex flex-col p-6 sm:p-8 rounded-2xl bg-white border-2 transition-all duration-300 hover:-translate-y-1 h-full ${
    isHighlighted
      ? "border-moody-blue-500 shadow-xl shadow-moody-blue-500/20 md:scale-105 z-10"
      : "border-moody-blue-100 hover:border-moody-blue-300"
  }`}
>
  {
    isHighlighted && (
      <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-moody-blue-600 text-white text-sm font-bold px-4 py-1.5 rounded-full uppercase tracking-wider whitespace-nowrap shadow-md">
        {highlightText}
      </div>
    )
  }

  <header class="mb-6 flex flex-col items-center text-center">
    <h3 class="text-xl font-bold text-gray-900 mb-2">{title}</h3>
    <p class="text-sm text-gray-500 mb-6 min-h-[40px]">{description}</p>
    <div class="flex items-baseline gap-1 text-moody-blue-700">
      <span class="text-xl font-semibold">$</span>
      <span class="text-5xl font-extrabold tracking-tight"
        >{formattedPrice}</span
      >
    </div>
    <span class="text-sm text-gray-500 mt-2">por sesión</span>
  </header>

  <ul class="flex flex-col gap-4 mb-8 flex-1 w-full max-w-[240px] mx-auto">
    {
      features.map((feature) => (
        <li class="flex items-start gap-3">
          <Check className="w-5 h-5 text-green-500 shrink-0 mt-0.5" />
          <span class="text-gray-700 text-sm leading-tight text-left">
            {feature}
          </span>
        </li>
      ))
    }
  </ul>

  <footer class="mt-auto flex justify-center w-full">
    <ExternalButton
      href={href}
      text="Agendar ahora"
      icon={ArrowRight}
      {...rest as any}
    />
  </footer>
</article>
