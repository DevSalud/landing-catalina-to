---
const {
  price,
  salePrice,
  disponibility,
  hours,
  payment,
  title,
  badge,
} = Astro.props;
import { ArrowRight, CalendarDays, Clock, CreditCard } from "lucide-react";
import ExternalButton from "../common/ExternalButton.astro";

const formattedToClp = (value: number) => {
  return new Intl.NumberFormat("es-CL", {
    style: "currency",
    currency: "CLP",
    minimumFractionDigits: 0,
  })
    .format(value)
    .replace("CLP", "")
    .trim();
};

const formattedPrice = formattedToClp(price);
const formattedSalePrice = salePrice ? formattedToClp(salePrice) : null;

const hasDiscount = salePrice && price > salePrice;
const totalDiscount = hasDiscount ? price - salePrice : 0;
const formattedTotalDiscount = formattedToClp(totalDiscount);
---

<article
  class="relative flex flex-col items-center rounded-2xl p-8 transition-all duration-300 h-full w-full bg-white shadow-lg hover:shadow-xl border border-moody-blue-100 hover:scale-105"
>
  <header
    class="flex flex-col gap-4 w-full mb-8 text-center border-b border-gray-100 pb-8"
  >
    {
      badge && (
        <span class="text-xs font-bold px-3 py-1 rounded-full w-fit mx-auto uppercase tracking-wider bg-moody-blue-50 text-moody-blue-700">
          {badge}
        </span>
      )
    }

    <h3
      class="text-xl font-bold text-gray-900 min-h-[3rem] flex items-center justify-center"
    >
      {title}
    </h3>

    <div class="flex flex-col items-center justify-center min-h-[5rem]">
      {
        hasDiscount ? (
          <>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="text-4xl font-extrabold text-moody-blue-700">
                {formattedSalePrice}
              </span>
              <span class="text-lg text-gray-400 line-through font-medium">
                {formattedPrice}
              </span>
            </div>
            <span class="text-gray-500 text-sm">por sesión</span>
            <div class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-bold flex items-center gap-1.5 shadow-sm border border-green-200 mt-6">
              <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse" />
              Ahorra {formattedTotalDiscount} con Fonasa
            </div>
          </>
        ) : (
          <span class="text-4xl font-extrabold text-moody-blue-700">
            {formattedPrice}
          </span>
          <span class="text-gray-500 text-sm mt-3">por sesión</span>
        )
      }
    </div>
  </header>

  <div class="flex flex-col gap-4 w-full mb-8 flex-grow">
    <div class="flex items-center gap-3 text-gray-600">
      <CalendarDays className="w-5 h-5 text-moody-blue-500 shrink-0 mt-0.5" />
      <span class="text-sm leading-tight">{disponibility}</span>
    </div>

    <div class="flex items-center gap-3 text-gray-600">
      <Clock className="w-5 h-5 text-moody-blue-500 shrink-0" />
      <span class="text-sm">{hours}</span>
    </div>

    <div class="flex items-center gap-3 text-gray-600">
      <CreditCard className="w-5 h-5 text-moody-blue-500 shrink-0" />
      <span class="text-sm">{payment}</span>
    </div>
  </div>

  <footer class="w-full mt-auto">
    <ExternalButton
      href="https://cal.com/catalina-herrera-ygpr9v"
      text="Agendar ahora"
      icon={ArrowRight}
    />
  </footer>
</article>
