---
import Whatsapp from '../icons/Whatsapp.astro'

interface Props extends astroHTML.JSX.AnchorHTMLAttributes {
	href: string
	text: string
	textClass?: string
}

const { href, text, textClass, ...rest } = Astro.props
---

<a
  href={href}
  {...rest}
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full bg-green-800 text-white font-semibold text-lg shadow-lg shadow-green-300/40 hover:bg-green-700 hover:shadow-xl hover:shadow-green-300/50 hover:-translate-y-0.5 transition-all duration-200 whitespace-nowrap"
>
  <Whatsapp />
  {text}
</a>
