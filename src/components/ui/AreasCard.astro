---
import { Picture } from 'astro:assets'

interface Props {
	title: string
	alt: string
	description: string
	image: ImageMetadata
}

const { title, alt, description, image } = Astro.props
---

<article
  class="group relative overflow-hidden rounded-2xl bg-white shadow-md hover:shadow-xl hover:shadow-moody-blue-200/40 transition-all duration-300 hover:-translate-y-1"
>
  <!-- Imagen -->
  <div class="relative h-48 overflow-hidden">
    <Picture
      src={image}
      alt={alt}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      style="transform: translateZ(0);"
      loading="lazy"
      decoding="async"
      formats={["avif", "webp"]}
      widths={[320, 400]}
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 400px"
      width={400}
      height={225}
    />
    <!-- Overlay gradiente sutil -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
    >
    </div>
  </div>

  <!-- Contenido -->
  <div class="p-6 flex flex-col gap-3">
    <h3 class="text-lg font-bold text-moody-blue-700 leading-snug">
      {title}
    </h3>
    <p class="text-gray-600 text-sm leading-relaxed !m-0">
      {description}
    </p>
  </div>
</article>
