---
import { Globe2, Home, MapPin } from 'lucide-react'
---

<section
  class="bg-moody-blue-950 flex flex-col justify-center h-full px-4 lg:px-0 text-white relative overflow-hidden"
  id="donde"
>
  <!-- Background Pattern -->
  <div
    class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-moody-blue-500 via-transparent to-transparent"
  >
  </div>

  <div
    class="flex flex-col h-full mt-20 mx-auto mb-20 max-w-7xl px-4 md:px-8 relative z-10"
  >
    <div class="mb-16">
      <h1 class="text-3xl md:text-4xl font-bold text-center mb-6">
        Cobertura de Atención
      </h1>
      <p class="text-center text-gray-300 text-lg max-w-2xl mx-auto">
        Llevando la terapia ocupacional donde la necesites. Combino la
        flexibilidad de la atención online con la cercanía de las visitas
        presenciales en zonas específicas.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full max-w-4xl mx-auto">
      <!-- Tarjeta Online -->
      <div
        class="bg-moody-blue-900/50 backdrop-blur-sm border border-moody-blue-700 p-8 rounded-2xl hover:bg-moody-blue-900 transition-colors group"
      >
        <div
          class="bg-mint-500/20 w-16 h-16 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
        >
          <Globe2 className="w-8 h-8 text-mint-400" />
        </div>
        <h2 class="text-2xl font-bold mb-4">Atención Online</h2>
        <p class="text-gray-300 mb-6 leading-relaxed">
          Disponible para todo Chile. Ideal para seguimiento continuo, asesorías
          parentales y flexibilidad horaria desde la comodidad de tu hogar.
        </p>
        <ul class="text-sm text-gray-400 space-y-2">
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-mint-400 rounded-full"></span>
            Cobertura nacional (Arica a Punta Arenas)
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-mint-400 rounded-full"></span>
            Sin traslados ni tiempos de espera
          </li>
        </ul>
      </div>

      <!-- Tarjeta Presencial -->
      <div
        class="bg-moody-blue-900/50 backdrop-blur-sm border border-moody-blue-700 p-8 rounded-2xl hover:bg-moody-blue-900 transition-colors group"
      >
        <div
          class="bg-orchid-500/20 w-16 h-16 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
        >
          <Home className="w-8 h-8 text-orchid-400" />
        </div>
        <h2 class="text-2xl font-bold mb-4">Atención a Domicilio</h2>
        <p class="text-gray-300 mb-6 leading-relaxed">
          Sesiones presenciales exclusivamente en la comodidad de tu hogar para
          las siguientes comunas:
        </p>
        <div class="flex flex-wrap gap-2">
          <span
            class="px-3 py-1 bg-moody-blue-800 rounded-full text-sm border border-moody-blue-600 text-white"
            >Maipú</span
          >
          <span
            class="px-3 py-1 bg-moody-blue-800 rounded-full text-sm border border-moody-blue-600 text-white"
            >Cerrillos</span
          >
          <span
            class="px-3 py-1 bg-moody-blue-800 rounded-full text-sm border border-moody-blue-600 text-white"
            >Padre Hurtado</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
