---
import { WHERE_TEXTS } from '@/data/where'
import OnlineImage from '../../public/images/where/online.webp'
import PresencialImage from '../../public/images/where/presencial.webp'
import ImageCard from './ui/ImageCard.astro'
---

<section
  class="bg-moody-blue-900 flex flex-col justify-center h-full px-4 lg:px-0 text-white relative overflow-hidden py-24"
  id="donde"
>
  <!-- Background Pattern -->
  <div
    class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-moody-blue-500 via-transparent to-transparent"
  >
  </div>
  <div
    class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-orchid-500 via-transparent to-transparent"
  >
  </div>

  <div
    class="flex flex-col h-full mx-auto max-w-7xl px-4 md:px-8 relative z-10"
  >
    <div class="mb-16 text-center max-w-3xl mx-auto space-y-4">
      <h2 class="text-mint-400 font-medium tracking-wide uppercase text-sm">
        {WHERE_TEXTS.subtitle}
      </h2>
      <h1 class="text-3xl md:text-4xl font-bold mb-6 text-white">
        {WHERE_TEXTS.title}
      </h1>
      <p class="text-gray-300 text-lg leading-relaxed">
        {WHERE_TEXTS.description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full max-w-5xl mx-auto">
      <!-- Tarjeta Online -->
      <ImageCard
        title={WHERE_TEXTS.cards.online.title}
        description={WHERE_TEXTS.cards.online.description}
        image={OnlineImage}
        alt={WHERE_TEXTS.cards.online.alt}
        variant="mint"
      >
        <ul slot="footer" class="space-y-3">
          {
            WHERE_TEXTS.cards.online.features.map((feature) => (
              <li class="flex items-center gap-3 text-gray-200 font-medium">
                <div class="w-6 h-6 rounded-full bg-mint-500/30 flex items-center justify-center shrink-0 border border-mint-500/50">
                  <div class="w-2 h-2 bg-mint-400 rounded-full" />
                </div>
                {feature}
              </li>
            ))
          }
        </ul>
      </ImageCard>

      <!-- Tarjeta Presencial -->
      <ImageCard
        title={WHERE_TEXTS.cards.presential.title}
        description={WHERE_TEXTS.cards.presential.description}
        image={PresencialImage}
        alt={WHERE_TEXTS.cards.presential.alt}
        variant="orchid"
      >
        <div slot="footer" class="flex flex-wrap gap-2 justify-center">
          {
            WHERE_TEXTS.cards.presential.communes.map((commune) => (
              <span class="px-4 py-1.5 bg-orchid-500/30 rounded-full text-sm border border-orchid-500/50 text-white font-semibold backdrop-blur-sm shadow-sm">
                {commune}
              </span>
            ))
          }
        </div>
      </ImageCard>
    </div>
  </div>
</section>
