---
import PriceCard from "./ui/PriceCard.astro";
---

<section class="bg-white flex flex-col justify-center h-full" id="valor">
  <div
    class="flex flex-col gap-12 py-20 items-center max-w-7xl px-4 md:px-8 mx-auto"
  >
    <div class="max-w-3xl mx-auto">
      <h1
        class="text-3xl md:text-4xl font-bold text-center text-moody-blue-800 mb-4"
      >
        Planes de Atención
      </h1>
      <p class="text-center text-gray-600 text-lg">
        Elige la modalidad que mejor se adapte a tu familia. Atención presencial
        exclusiva en Maipú, Cerrillos y Padre Hurtado.
      </p>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full items-start"
    >
      <PriceCard
        title="Online Fonasa"
        badge="Valor Preferencial"
        price={25000}
        salePrice={20000}
        disponibility="Lunes, Miércoles, Viernes y Sábado"
        hours="45 minutos"
        payment="Pago por Transferencia"
      />

      <PriceCard
        title="Atención Online"
        badge="Todo Chile"
        price={25000}
        disponibility="Lunes, Miércoles, Viernes y Sábado"
        hours="45 minutos"
        payment="Pago por Transferencia"
      />

      <PriceCard
        title="Presencial Domicilio"
        badge="Maipú, Cerrillos, P. Hurtado"
        price={25000}
        disponibility="Lunes, Miércoles, Viernes y Sábado"
        hours="45 minutos"
        payment="Pago por Transferencia"
      />
    </div>
  </div>
</section>
