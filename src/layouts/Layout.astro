---
import '../styles/global.css'
import { createPersonSchema, createWebSiteSchema } from '../lib/seoSchemas.ts'

interface LayoutProps {
	title?: string
	description?: string
	canonical?: string
	ogTitle?: string
	ogDescription?: string
	ogImage?: string
	ogImageAlt?: string
	ogUrl?: string
	ogType?: string
	schema?: object | object[]
	articlePublishedTime?: string | Date
	articleTags?: string[]
	noindex?: boolean
}

const {
	title,
	description,
	canonical,
	ogTitle,
	ogDescription,
	ogImage,
	ogImageAlt,
	ogUrl,
	ogType,
	schema,
	articlePublishedTime,
	articleTags,
	noindex,
} = Astro.props as LayoutProps

// URL del sitio desde la config de Astro con fallback
const SITE_URL = (
	Astro.site ? Astro.site.toString() : 'https://www.cataterapias.cl'
).replace(/\/$/, '')
const siteName = 'Catalina Herrera'

function toAbsolute(url: string | undefined, base: string): string | undefined {
	if (!url) {
		return undefined
	}
	return url.startsWith('http') ? url : `${base}${url}`
}

// Valores por defecto (como estaban antes)
const defaultTitle =
	'Catalina Herrera | Terapia Ocupacional para Niños en Maipú'
const defaultDescription =
	'Terapia Ocupacional orientada a niños y adolescentes en Maipú, Santiago. Ayudo a tu pequeño con sesiones personalizadas y actividades significativas. ¡Agenda hoy!'
const defaultImage = '/images/Catalina.webp'
const defaultImageAlt = 'Foto de Catalina Herrera sonriendo'
const defaultType = 'website'

// Resolución final
const pageTitle = title ?? defaultTitle
const pageDescription = description ?? defaultDescription
const canonicalFinalRaw = canonical ?? ogUrl ?? SITE_URL
const canonicalFinal = canonicalFinalRaw.startsWith('http')
	? canonicalFinalRaw
	: `${SITE_URL}${canonicalFinalRaw}`
const ogTitleFinal = ogTitle ?? pageTitle
const ogDescriptionFinal = ogDescription ?? pageDescription
// Asegurar URLs absolutas para imágenes
const ogImageFinal =
	toAbsolute(ogImage, SITE_URL) ?? `${SITE_URL}${defaultImage}`
const ogImageAltFinal = ogImageAlt ?? defaultImageAlt
const ogUrlFinal = ogUrl ?? canonicalFinal
const ogTypeFinal = ogType ?? defaultType

const isArticle = ogTypeFinal === 'article'

const schemaFallback = createPersonSchema(SITE_URL, {
	includeOfferCatalog: true,
})

const schemaProp = schema
	? Array.isArray(schema)
		? schema
		: [schema]
	: schemaFallback

const graphNodes = [...schemaProp.flat(), createWebSiteSchema(SITE_URL)]

const schemaFinal = {
	'@context': 'https://schema.org',
	'@graph': graphNodes,
}

const schemaJson = JSON.stringify(schemaFinal)
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#ffffff" />

    

    <link rel="dns-prefetch" href="https://api.whatsapp.com">

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:title" content={ogTitleFinal} />
    <meta property="og:description" content={ogDescriptionFinal} />
    <meta property="og:image" content={ogImageFinal} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    
    <meta property="og:image:alt" content={ogImageAltFinal} />
    <meta property="og:url" content={ogUrlFinal} />
    <meta property="og:type" content={ogTypeFinal} />

    {isArticle && articlePublishedTime && (
      <meta
        property="article:published_time"
        content={new Date(articlePublishedTime).toISOString()}
      />
    )}

    {isArticle && Array.isArray(articleTags) && (
      <Fragment>
        {articleTags.map((tag: string) => (
          <meta property="article:tag" content={tag} />
        ))}
      </Fragment>
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitleFinal} />
    <meta name="twitter:description" content={ogDescriptionFinal} />
    <meta name="twitter:image" content={ogImageFinal} />
    <meta name="twitter:url" content={ogUrlFinal} />
    <meta name="twitter:image:alt" content={ogImageAltFinal} />

    <link rel="canonical" href={canonicalFinal} />

    {
      schemaJson && (
        <script is:inline type="application/ld+json" set:html={schemaJson}>
        </script>
      )
    }
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
  }
</style>
