---
import '../styles/global.css'
import FloatingWhatsapp from '../components/ui/FloatingWhatsapp.astro'
import {
	DEFAULT_DESCRIPTION,
	DEFAULT_OG_IMAGE,
	DEFAULT_OG_IMAGE_ALT,
	DEFAULT_TITLE,
	SITE_NAME,
} from '../lib/constants'
import { createPersonSchema, createWebSiteSchema } from '../lib/seoSchemas.ts'

interface LayoutProps {
	title?: string
	description?: string
	canonical?: string
	ogTitle?: string
	ogDescription?: string
	ogImage?: string
	ogImageAlt?: string
	ogUrl?: string
	ogType?: string
	schema?: object | object[]
	articlePublishedTime?: string | Date
	articleTags?: string[]
	noindex?: boolean
}

const {
	title,
	description,
	canonical,
	ogTitle,
	ogDescription,
	ogImage,
	ogImageAlt,
	ogUrl,
	ogType,
	schema,
	articlePublishedTime,
	articleTags,
	noindex,
} = Astro.props as LayoutProps

// URL del sitio desde la config de Astro con fallback
const SITE_URL = (
	Astro.site ? Astro.site.toString() : 'https://www.cataterapias.cl'
).replace(/\/$/, '')
const siteName = SITE_NAME

function toAbsolute(url: string | undefined, base: string): string | undefined {
	if (!url) {
		return undefined
	}
	return url.startsWith('http') ? url : `${base}${url}`
}

// Valores por defecto desde constants.ts
const defaultTitle = DEFAULT_TITLE
const defaultDescription = DEFAULT_DESCRIPTION
const defaultImage = DEFAULT_OG_IMAGE
const defaultImageAlt = DEFAULT_OG_IMAGE_ALT
const defaultType = 'website'

// Resolución final
const pageTitle = title ?? defaultTitle
const pageDescription = description ?? defaultDescription
const canonicalFinalRaw = canonical ?? ogUrl ?? SITE_URL
const canonicalFinal = canonicalFinalRaw.startsWith('http')
	? canonicalFinalRaw
	: `${SITE_URL}${canonicalFinalRaw}`
const ogTitleFinal = ogTitle ?? pageTitle
const ogDescriptionFinal = ogDescription ?? pageDescription
// Asegurar URLs absolutas para imágenes
const ogImageFinal =
	toAbsolute(ogImage, SITE_URL) ?? `${SITE_URL}${defaultImage}`
const ogImageAltFinal = ogImageAlt ?? defaultImageAlt
const ogUrlFinal = ogUrl ?? canonicalFinal
const ogTypeFinal = ogType ?? defaultType

const isArticle = ogTypeFinal === 'article'

const schemaFallback = createPersonSchema(SITE_URL, {
	includeOfferCatalog: true,
})

const schemaProp = schema
	? Array.isArray(schema)
		? schema
		: [schema]
	: schemaFallback

const graphNodes = [...schemaProp.flat(), createWebSiteSchema(SITE_URL)]

const schemaFinal = {
	'@context': 'https://schema.org',
	'@graph': graphNodes,
}

const schemaJson = JSON.stringify(schemaFinal)
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Umami Analytics -->
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="795c261b-fc21-4c91-8129-78c24de8460a"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#ffffff" />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/quicksand-v36-latin-regular.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/quicksand-v36-latin-500.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/quicksand-v36-latin-600.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/quicksand-v36-latin-700.woff2" as="font" type="font/woff2" crossorigin>

    <link rel="dns-prefetch" href="https://api.whatsapp.com">

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:title" content={ogTitleFinal} />
    <meta property="og:description" content={ogDescriptionFinal} />
    <meta property="og:image" content={ogImageFinal} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    
    <meta property="og:image:alt" content={ogImageAltFinal} />
    <meta property="og:url" content={ogUrlFinal} />
    <meta property="og:type" content={ogTypeFinal} />

    {isArticle && articlePublishedTime && (
      <meta
        property="article:published_time"
        content={new Date(articlePublishedTime).toISOString()}
      />
    )}

    {isArticle && Array.isArray(articleTags) && (
      <Fragment>
        {articleTags.map((tag: string) => (
          <meta property="article:tag" content={tag} />
        ))}
      </Fragment>
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitleFinal} />
    <meta name="twitter:description" content={ogDescriptionFinal} />
    <meta name="twitter:image" content={ogImageFinal} />
    <meta name="twitter:url" content={ogUrlFinal} />
    <meta name="twitter:image:alt" content={ogImageAltFinal} />

    <link rel="canonical" href={canonicalFinal} />

    {
      schemaJson && (
        <script is:inline type="application/ld+json" set:html={schemaJson}>
        </script>
      )
    }
  </head>
  <body>
    <slot />
    <FloatingWhatsapp />

    <!-- Scroll Reveal Observer -->
    <script is:inline>
      (function () {
        const els = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
        if (!els.length) return;
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
  }
</style>
