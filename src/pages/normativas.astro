---
import { CheckCircle2, FileText } from 'lucide-react'
import Footer from '../components/sections/Footer.astro'
import Navbar from '../components/sections/Navbar.astro'
import {
	NORMATIVAS,
	NORMATIVAS_SUBTITLE,
	NORMATIVAS_TITLE,
} from '../data/normativas.ts'
import Layout from '../layouts/Layout.astro'
import { createBreadcrumbListSchema } from '../lib/seoSchemas.ts'

export const prerender = true

// SEO Constants
const siteBase = Astro.site
	? Astro.site.toString().replace(/\/$/, '')
	: 'https://www.cataterapias.cl'
const metaTitle = 'Normativas de Atención | Catalina Herrera'
const metaDescription =
	'Conoce las normas de funcionamiento, políticas de cancelación, puntualidad y detalles administrativos sobre la atención de Terapia Ocupacional.'
const canonicalUrl = `${siteBase}/normativas`
const defaultImage = '/images/Catalina.webp'
const ogImage = defaultImage.startsWith('http')
	? defaultImage
	: `${siteBase}${defaultImage}`
const ogImageAlt = 'Foto de Catalina Herrera sonriendo'

// Schema.org
const schema = [
	createBreadcrumbListSchema([
		{ name: 'Inicio', item: `${siteBase}/` },
		{ name: 'Normativas', item: canonicalUrl },
	]),
]
---

<Layout
  title={metaTitle}
  description={metaDescription}
  canonical={canonicalUrl}
  ogTitle={metaTitle}
  ogDescription={metaDescription}
  ogImage={ogImage}
  ogUrl={canonicalUrl}
  ogImageAlt={ogImageAlt}
  ogType="website"
  schema={schema}
>
  <Navbar />

  <main class="min-h-screen bg-gradient-to-b from-white to-moody-blue-200/30">
    <!-- Header Section -->
    <div class="pt-32 pb-12 px-4 md:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div
          class="inline-flex items-center justify-center p-3 bg-moody-blue-100 rounded-full mb-6"
        >
          <FileText className="w-8 h-8 text-moody-blue-600" />
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-moody-blue-700 mb-4">
          {NORMATIVAS_TITLE}
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
          {NORMATIVAS_SUBTITLE}
        </p>
      </div>
    </div>

    <!-- Content Section -->
    <div class="max-w-4xl mx-auto px-4 md:px-8 pb-24">
      <div class="grid gap-8">
        {
          NORMATIVAS.map((seccion) => (
            <section class="bg-white rounded-2xl p-8 shadow-lg shadow-moody-blue-100/50 border border-moody-blue-100 transition-all hover:shadow-xl">
              <h2 class="text-2xl font-bold text-moody-blue-700 mb-6 flex items-center gap-3">
                {seccion.title}
              </h2>
              <ul class="space-y-4">
                {seccion.items.map((item) => (
                  <li class="flex items-start gap-3 text-gray-700 text-lg leading-relaxed">
                    <CheckCircle2 className="w-6 h-6 text-mint-500 shrink-0 mt-1" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>

      <!-- CTA Final -->
      <div class="mt-16 text-center">
        <p class="text-gray-600 mb-6">¿Tienes dudas sobre alguna normativa?</p>
        <a
          href="/#contacto"
          class="inline-flex items-center gap-2 bg-moody-blue-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-moody-blue-700 transition-colors shadow-lg hover:shadow-moody-blue-200"
        >
          Contáctame
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
