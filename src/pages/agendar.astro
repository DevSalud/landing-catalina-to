---
import { Copy, FileText, Mail } from 'lucide-react'
import WhatsappIcon from '../components/icons/Whatsapp.astro'
import Footer from '../components/sections/Footer.astro'
import Navbar from '../components/sections/Navbar.astro'
import Layout from '../layouts/Layout.astro'
import {
	BANK_ACCOUNT_NUMBER,
	BANK_ACCOUNT_TYPE,
	BANK_NAME,
	BANK_RECEIPT_EMAIL,
	BANK_RUT,
	CALENDAR_LINK_DOMICILIO,
	CALENDAR_LINK_FONASA,
	CALENDAR_LINK_PARTICULAR,
	CALENDAR_NAMESPACE,
	EMAIL,
	PHONE_RAW,
	PROFESSIONAL_NAME,
} from '../lib/constants'

// Obtenemos el servicio de la URL para saber qué evento pre-cargar
const servicio = Astro.url.searchParams.get('servicio') || ''

// Determinamos el link correspondiente
let calLink = CALENDAR_NAMESPACE

if (servicio === 'particular') {
	calLink = CALENDAR_LINK_PARTICULAR
} else if (servicio === 'fonasa') {
	calLink = CALENDAR_LINK_FONASA
} else if (servicio === 'domicilio') {
	calLink = CALENDAR_LINK_DOMICILIO
}

const siteBase = Astro.site
	? Astro.site.toString().replace(/\/$/, '')
	: 'https://cataterapia.cl'
const metaTitle = 'Agendar Sesión | Catalina Herrera'
const metaDescription =
	'Reserva tu hora de Terapia Ocupacional presencial o a domicilio en Maipú. Sigue los pasos de abono para asegurar la disponibilidad de la sesión.'
const canonicalUrl = `${siteBase}/agendar`
---

<Layout
  title={metaTitle}
  description={metaDescription}
  canonical={canonicalUrl}
>
  <Navbar />

  <main
    class="min-h-screen bg-gradient-to-b from-white via-moody-blue-50 to-moody-blue-200/30 pt-32 pb-20"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Encabezado -->
      <div class="text-center mb-12">
        <h1
          class="text-3xl md:text-5xl font-extrabold text-moody-blue-900 tracking-tight mb-4"
        >
          Reserva de Horas
        </h1>
        <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto">
          Para confirmar tu sesión, requerimos un abono de $10.000 para reservar
          el box clínico. Sigue las instrucciones de transferencia y elige tu
          hora.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- Columna Izquierda: Datos de Pago (lg:col-span-5) -->
        <section
          class="lg:col-span-5 bg-white/80 backdrop-blur-md rounded-3xl p-6 sm:p-8 shadow-xl shadow-moody-blue-100/50 border border-moody-blue-100/80"
        >
          <div class="flex items-center gap-3 mb-6">
            <div class="bg-moody-blue-100 p-2.5 rounded-2xl">
              <FileText className="w-6 h-6 text-moody-blue-600" />
            </div>
            <h2 class="text-2xl font-bold text-gray-900">
              1. Datos de Transferencia
            </h2>
          </div>

          <p class="text-gray-600 text-sm mb-6 leading-relaxed">
            Transfiere el abono de <strong>$10.000</strong> (que se descontará del
            valor total de la consulta) en un plazo máximo de <strong
              >4 horas</strong
            > para asegurar tu box clínico.
          </p>

          <!-- Tarjeta de Datos Copiables -->
          <div
            class="bg-moody-blue-50/70 rounded-2xl p-5 border border-moody-blue-100/60 mb-6 space-y-4"
          >
            <!-- Banco -->
            <div
              class="flex justify-between items-center py-2 border-b border-moody-blue-100/30"
            >
              <div class="flex flex-col">
                <span
                  class="text-xs text-gray-500 uppercase tracking-wider font-semibold"
                  >Banco</span
                >
                <span class="text-gray-800 font-medium" id="bank-name"
                  >{BANK_NAME}</span
                >
              </div>
              <button
                class="copy-btn cursor-pointer text-moody-blue-600 hover:text-moody-blue-800 p-1.5 rounded-lg hover:bg-white transition-colors"
                data-copy={BANK_NAME}
                title="Copiar banco"
              >
                <Copy className="w-4 h-4" />
              </button>
            </div>

            <!-- Tipo de Cuenta -->
            <div
              class="flex justify-between items-center py-2 border-b border-moody-blue-100/30"
            >
              <div class="flex flex-col">
                <span
                  class="text-xs text-gray-500 uppercase tracking-wider font-semibold"
                  >Tipo de Cuenta</span
                >
                <span class="text-gray-800 font-medium" id="account-type"
                  >{BANK_ACCOUNT_TYPE}</span
                >
              </div>
              <button
                class="copy-btn cursor-pointer text-moody-blue-600 hover:text-moody-blue-800 p-1.5 rounded-lg hover:bg-white transition-colors"
                data-copy={BANK_ACCOUNT_TYPE}
                title="Copiar tipo"
              >
                <Copy className="w-4 h-4" />
              </button>
            </div>

            <!-- Número de Cuenta -->
            <div
              class="flex justify-between items-center py-2 border-b border-moody-blue-100/30"
            >
              <div class="flex flex-col">
                <span
                  class="text-xs text-gray-500 uppercase tracking-wider font-semibold"
                  >Número de Cuenta</span
                >
                <span class="text-gray-800 font-bold" id="account-number"
                  >{BANK_ACCOUNT_NUMBER}</span
                >
              </div>
              <button
                class="copy-btn cursor-pointer text-moody-blue-600 hover:text-moody-blue-800 p-1.5 rounded-lg hover:bg-white transition-colors"
                data-copy={BANK_ACCOUNT_NUMBER}
                title="Copiar número"
              >
                <Copy className="w-4 h-4" />
              </button>
            </div>

            <!-- RUT -->
            <div
              class="flex justify-between items-center py-2 border-b border-moody-blue-100/30"
            >
              <div class="flex flex-col">
                <span
                  class="text-xs text-gray-500 uppercase tracking-wider font-semibold"
                  >RUT</span
                >
                <span class="text-gray-800 font-bold" id="bank-rut"
                  >{BANK_RUT}</span
                >
              </div>
              <button
                class="copy-btn cursor-pointer text-moody-blue-600 hover:text-moody-blue-800 p-1.5 rounded-lg hover:bg-white transition-colors"
                data-copy={BANK_RUT}
                title="Copiar RUT"
              >
                <Copy className="w-4 h-4" />
              </button>
            </div>

            <!-- Destinatario -->
            <div
              class="flex justify-between items-center py-2 border-b border-moody-blue-100/30"
            >
              <div class="flex flex-col">
                <span
                  class="text-xs text-gray-500 uppercase tracking-wider font-semibold"
                  >Nombre</span
                >
                <span class="text-gray-800 font-medium" id="prof-name"
                  >{PROFESSIONAL_NAME}</span
                >
              </div>
              <button
                class="copy-btn cursor-pointer text-moody-blue-600 hover:text-moody-blue-800 p-1.5 rounded-lg hover:bg-white transition-colors"
                data-copy={PROFESSIONAL_NAME}
                title="Copiar nombre"
              >
                <Copy className="w-4 h-4" />
              </button>
            </div>

            <!-- Correo -->
            <div class="flex justify-between items-center py-2">
              <div class="flex flex-col">
                <span
                  class="text-xs text-gray-500 uppercase tracking-wider font-semibold"
                  >Correo de Destino</span
                >
                <span
                  class="text-gray-800 font-medium break-all"
                  id="bank-email">{BANK_RECEIPT_EMAIL}</span
                >
              </div>
              <button
                class="copy-btn cursor-pointer text-moody-blue-600 hover:text-moody-blue-800 p-1.5 rounded-lg hover:bg-white transition-colors"
                data-copy={BANK_RECEIPT_EMAIL}
                title="Copiar correo"
              >
                <Copy className="w-4 h-4" />
              </button>
            </div>
          </div>

          <!-- Canales de Envío de Comprobante -->
          <div class="space-y-3">
            <span
              class="text-xs font-bold text-gray-500 uppercase tracking-wider block mb-1"
            >
              Envía tu comprobante a:
            </span>

            <!-- WhatsApp -->
            <a
              href={`https://api.whatsapp.com/send?phone=${PHONE_RAW}&text=Hola%20Catalina,%20adjunto%20comprobante%20de%20abono%20para%20mi%20sesi%C3%B3n.`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2.5 w-full bg-green-700 hover:bg-green-800 text-white font-semibold py-3 px-4 rounded-xl transition-all shadow-md shadow-green-200 cursor-pointer"
            >
              <WhatsappIcon />
              Enviar por WhatsApp
            </a>

            <!-- Correo -->
            <a
              href={`mailto:${EMAIL}?subject=Comprobante%20de%20Abono%20Terapia%20Ocupacional`}
              class="flex items-center justify-center gap-2.5 w-full bg-moody-blue-600 hover:bg-moody-blue-700 text-white font-semibold py-3 px-4 rounded-xl transition-all shadow-md shadow-moody-blue-200 cursor-pointer"
            >
              <Mail className="w-5 h-5" />
              Enviar por Correo
            </a>
          </div>

          <!-- Política Importante -->
          <div
            class="mt-6 p-4 bg-amber-50 rounded-2xl border border-amber-100 text-amber-800 text-xs leading-relaxed"
          >
            <strong>Importante:</strong> Las horas reservadas tienen un plazo máximo
            de 4 horas para ser abonadas (o hasta las 10:00 AM del día siguiente
            si agendas de noche). Pasado este tiempo la hora quedará sujeta a cancelación
            para permitir que otros pacientes puedan optar por el bloque.
          </div>
        </section>

        <!-- Columna Derecha: Calendario Cal.com Inline (lg:col-span-7) -->
        <section
          class="lg:col-span-7 bg-white rounded-3xl p-4 sm:p-6 shadow-xl shadow-moody-blue-100/50 border border-moody-blue-100 min-h-[600px] flex flex-col"
        >
          <div class="flex items-center gap-3 mb-6 px-2 sm:px-4">
            <div class="bg-moody-blue-100 p-2.5 rounded-2xl">
              <span class="text-moody-blue-600 font-bold text-lg">2</span>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">
              Selecciona tu Fecha y Hora
            </h2>
          </div>

          <!-- Widget de Cal.com -->
          <div class="flex-1 w-full relative" style="min-height: 600px;">
            <div
              id="cal-inline-widget"
              class="w-full h-full min-h-[600px] overflow-hidden rounded-2xl bg-gray-50 border border-gray-100"
            >
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script is:inline define:vars={{ calLink }}>
  // Inicialización del Calendario Inline de Cal.com
  document.addEventListener("DOMContentLoaded", () => {
    // Esperar a que el objeto Cal esté cargado de Layout.astro
    const checkCal = setInterval(() => {
      if (
        window.Cal &&
        window.Cal.ns &&
        window.Cal.ns["catalina-herrera-ygpr9v"]
      ) {
        clearInterval(checkCal);

        // Cargar el widget inline
        window.Cal.ns["catalina-herrera-ygpr9v"]("inline", {
          elementOrSelector: "#cal-inline-widget",
          calLink: calLink,
          layout: "month_view",
          styles: {
            branding: {
              brandColor: "#5434ce",
            },
          },
        });
      }
    }, 100);

    // Lógica para copiar datos al portapapeles de manera interactiva
    const copyButtons = document.querySelectorAll(".copy-btn");
    copyButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const textToCopy = button.getAttribute("data-copy");
        if (!textToCopy) return;

        navigator.clipboard
          .writeText(textToCopy)
          .then(() => {
            // Cambiar temporalmente el ícono a un check de éxito
            const originalInnerHTML = button.innerHTML;
            button.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check text-green-600"><path d="M20 6 9 17l-5-5"/></svg>
          `;
            button.classList.add("bg-green-50");

            setTimeout(() => {
              button.innerHTML = originalInnerHTML;
              button.classList.remove("bg-green-50");
            }, 2000);
          })
          .catch((err) => {
            console.error("Error al copiar texto: ", err);
          });
      });
    });
  });
</script>
