---
import Footer from '../components/sections/Footer.astro'
import Navbar from '../components/sections/Navbar.astro'
import { CitaProcessor } from '../components/ui/CitaProcessor.tsx'
import Layout from '../layouts/Layout.astro'

export const prerender = false
---

<Layout
  title="Procesando Solicitud | Catalina Herrera"
  description="Página de procesamiento de citas"
  noindex={true}
>
  <Navbar />

  <main
    class="min-h-screen flex items-center justify-center bg-moody-blue-50 px-4"
  >
    <CitaProcessor client:only="react" />
  </main>

  <Footer />
</Layout>
